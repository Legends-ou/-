{
  "name": "image-renamer-tauri",
  "private": true,
  "version": "0.2.0",
  "description": "A lightweight desktop tool for rule-based and AI-assisted image renaming.",
  "author": "OH WorkSpace",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "web": "vite --host 127.0.0.1 --open /",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-env.ps1",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-dev.ps1",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
